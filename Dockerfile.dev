# Shaperail Framework — Build + Test Container
# Used by CI and contributors who don't have Rust installed locally

FROM rust:1.75-slim AS base
RUN apt-get update && apt-get install -y \
    pkg-config libssl-dev libpq-dev curl \
    && rm -rf /var/lib/apt/lists/*
RUN cargo install sqlx-cli --features postgres --no-default-features

WORKDIR /framework

# Cache dependency layer (rebuild only when Cargo.toml changes)
COPY Cargo.toml Cargo.lock ./
COPY shaperail-core/Cargo.toml ./shaperail-core/
COPY shaperail-codegen/Cargo.toml ./shaperail-codegen/
COPY shaperail-runtime/Cargo.toml ./shaperail-runtime/
COPY shaperail-cli/Cargo.toml ./shaperail-cli/
RUN mkdir -p shaperail-core/src shaperail-codegen/src shaperail-runtime/src shaperail-cli/src \
    && echo "fn main() {}" > shaperail-cli/src/main.rs \
    && for c in shaperail-core shaperail-codegen shaperail-runtime; do echo "" > $c/src/lib.rs; done \
    && cargo build --workspace 2>/dev/null || true \
    && rm -rf shaperail-core/src shaperail-codegen/src shaperail-runtime/src shaperail-cli/src

# Full build
COPY . .
RUN cargo build --workspace

CMD ["cargo", "test", "--workspace"]
