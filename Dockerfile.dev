# SteelAPI Framework — Build + Test Container
# Used by CI and contributors who don't have Rust installed locally

FROM rust:1.75-slim AS base
RUN apt-get update && apt-get install -y \
    pkg-config libssl-dev libpq-dev curl \
    && rm -rf /var/lib/apt/lists/*
RUN cargo install sqlx-cli --features postgres --no-default-features

WORKDIR /framework

# Cache dependency layer (rebuild only when Cargo.toml changes)
COPY Cargo.toml Cargo.lock ./
COPY steel-core/Cargo.toml ./steel-core/
COPY steel-codegen/Cargo.toml ./steel-codegen/
COPY steel-runtime/Cargo.toml ./steel-runtime/
COPY steel-cli/Cargo.toml ./steel-cli/
RUN mkdir -p steel-core/src steel-codegen/src steel-runtime/src steel-cli/src \
    && echo "fn main() {}" > steel-cli/src/main.rs \
    && for c in steel-core steel-codegen steel-runtime; do echo "" > $c/src/lib.rs; done \
    && cargo build --workspace 2>/dev/null || true \
    && rm -rf steel-core/src steel-codegen/src steel-runtime/src steel-cli/src

# Full build
COPY . .
RUN cargo build --workspace

CMD ["cargo", "test", "--workspace"]
